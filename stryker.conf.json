{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "src/core/**/*.ts",
    "src/core/**/*.tsx",
    "!src/core/**/*.spec.ts",
    "!src/core/**/*.test.ts"
  ]
}
